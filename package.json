{
  "name": "godoc-document-ack",
  "version": "1.0.0",
  "description": "Document Upload & Acknowledgement flow - GoDoc take-home assessment",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --node-arg=--experimental-sqlite src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --experimental-sqlite dist/server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-sqlite jest --runInBand",
    "migrate": "cross-env NODE_OPTIONS=--experimental-sqlite ts-node -T src/db/migrate.ts",
    "seed": "cross-env NODE_OPTIONS=--experimental-sqlite ts-node -T src/db/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.20.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}