# Committed per assessment instructions ("please also commit the environment variable to the repository").
# In a real production repo these would NOT be committed - see README "Known limitations" for why.
PORT=4000
DATABASE_PATH=./data/dev.db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
JWT_SECRET=dev-only-secret-change-before-any-real-deployment
